# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Required for the API server and the seed script.
# Without it the API server starts but returns 503 on /trays and /varieties.
DATABASE_URL=postgresql://user:password@localhost:5432/kilai

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001          # API server port
API_PORT=3001      # Must match PORT above — tells Vite proxy where to forward /api/*
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Mount path — must match the Vite proxy target and the OpenAPI servers[].url
BASE_PATH=/api
